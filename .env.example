# Open The Doorz - Root Environment Template

# -----------------------------------------------------------------------------
# Integration testing (fork mode)
# -----------------------------------------------------------------------------
# To run staking integration tests with forked Sepolia state:
# FORK_NETWORK=https://starknet-sepolia-rpc.example.com

# -----------------------------------------------------------------------------
# Preset generation
# -----------------------------------------------------------------------------
# Voyager API Key (required for validator presets generation)
# Get your key at: https://voyager.online/docs/api/getting-started
# VOYAGER_API_KEY=your_voyager_api_key

# -----------------------------------------------------------------------------
# Example backend (Privy + AVNU Paymaster)
# -----------------------------------------------------------------------------
# Used by examples/server/server.ts and examples/web Privy/onramp flows
# PRIVY_APP_ID=your_privy_app_id
# PRIVY_APP_SECRET=your_privy_app_secret
# AVNU_API_KEY=your_avnu_api_key
# AVNU_PAYMASTER_URL=https://sepolia.paymaster.avnu.fi

# -----------------------------------------------------------------------------
# Release / CI (local dry-run context)
# -----------------------------------------------------------------------------
# NPM_TOKEN=your_npm_publish_token